# OpenAI API Configuration
# Replace with your actual OpenAI API key in .env.local
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI API Base URL (optional, for custom endpoints)
OPENAI_API_BASE_URL=https://api.openai.com/v1

# Model to use for HTML analysis
OPENAI_MODEL=gpt-4o

# Public Site URL (for fetching HTML when not available in context)
# Set this to your Vercel deployment URL or production domain
NEXT_PUBLIC_SITE_URL=your_public_domain_here
#https://rb-sitecore-ehs-2026-rb-sitecore-eh.vercel.app